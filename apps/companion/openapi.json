{
  "openapi": "3.0.3",
  "info": {
    "title": "Open Resume Companion API",
    "version": "0.1.0",
    "description": "Local companion service for extracting job details from pasted job URLs."
  },
  "components": {
    "schemas": {
      "HealthResponseInput": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "service": {
            "type": "string"
          }
        },
        "required": [
          "ok",
          "service"
        ],
        "additionalProperties": false
      },
      "ExtractJobRequestInput": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "HTTP or HTTPS job posting URL to extract."
          }
        },
        "required": [
          "url"
        ],
        "additionalProperties": false
      },
      "JobExtractionResultInput": {
        "type": "object",
        "properties": {
          "sourceUrl": {
            "type": "string",
            "format": "uri"
          },
          "title": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "rawText": {
            "type": "string"
          },
          "extractionMethod": {
            "type": "string",
            "enum": [
              "json-ld",
              "readability",
              "playwright"
            ]
          },
          "extractedAt": {
            "type": "number",
            "description": "Unix timestamp in milliseconds."
          }
        },
        "required": [
          "sourceUrl",
          "title",
          "company",
          "location",
          "description",
          "rawText",
          "extractionMethod",
          "extractedAt"
        ],
        "additionalProperties": false
      },
      "CompanionErrorResponseInput": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "details": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ],
        "additionalProperties": false
      },
      "CrawlStatusInput": {
        "type": "string",
        "enum": [
          "pending",
          "crawling",
          "ready",
          "failed"
        ]
      },
      "CreateJobRequestInput": {
        "type": "object",
        "properties": {
          "sourceUrl": {
            "type": "string",
            "format": "uri",
            "description": "HTTP or HTTPS job posting URL to crawl."
          }
        },
        "required": [
          "sourceUrl"
        ],
        "additionalProperties": false
      },
      "JobIdParamsInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id"
        ],
        "additionalProperties": false
      },
      "CompanionJobInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "sourceUrl": {
            "type": "string",
            "format": "uri"
          },
          "crawlStatus": {
            "$ref": "#/components/schemas/CrawlStatusInput"
          },
          "crawlError": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "cleanedText": {
            "type": "string"
          },
          "createdAt": {
            "type": "number",
            "description": "Unix timestamp in milliseconds."
          },
          "updatedAt": {
            "type": "number",
            "description": "Unix timestamp in milliseconds."
          },
          "crawledAt": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "description": "Unix timestamp in milliseconds, or null before crawl success."
          }
        },
        "required": [
          "id",
          "sourceUrl",
          "crawlStatus",
          "crawlError",
          "cleanedText",
          "createdAt",
          "updatedAt",
          "crawledAt"
        ],
        "additionalProperties": false
      },
      "CompanionJobsResponseInput": {
        "type": "object",
        "properties": {
          "jobs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CompanionJobInput"
            }
          }
        },
        "required": [
          "jobs"
        ],
        "additionalProperties": false
      },
      "DeleteJobResponseInput": {
        "type": "object",
        "properties": {
          "deleted": {
            "type": "boolean"
          }
        },
        "required": [
          "deleted"
        ],
        "additionalProperties": false
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "service": {
            "type": "string"
          }
        },
        "required": [
          "ok",
          "service"
        ],
        "additionalProperties": false
      },
      "ExtractJobRequest": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "HTTP or HTTPS job posting URL to extract."
          }
        },
        "required": [
          "url"
        ],
        "additionalProperties": false
      },
      "JobExtractionResult": {
        "type": "object",
        "properties": {
          "sourceUrl": {
            "type": "string",
            "format": "uri"
          },
          "title": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "rawText": {
            "type": "string"
          },
          "extractionMethod": {
            "type": "string",
            "enum": [
              "json-ld",
              "readability",
              "playwright"
            ]
          },
          "extractedAt": {
            "type": "number",
            "description": "Unix timestamp in milliseconds."
          }
        },
        "required": [
          "sourceUrl",
          "title",
          "company",
          "location",
          "description",
          "rawText",
          "extractionMethod",
          "extractedAt"
        ],
        "additionalProperties": false
      },
      "CompanionErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "details": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ],
        "additionalProperties": false
      },
      "CrawlStatus": {
        "type": "string",
        "enum": [
          "pending",
          "crawling",
          "ready",
          "failed"
        ]
      },
      "CreateJobRequest": {
        "type": "object",
        "properties": {
          "sourceUrl": {
            "type": "string",
            "format": "uri",
            "description": "HTTP or HTTPS job posting URL to crawl."
          }
        },
        "required": [
          "sourceUrl"
        ],
        "additionalProperties": false
      },
      "JobIdParams": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id"
        ],
        "additionalProperties": false
      },
      "CompanionJob": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "sourceUrl": {
            "type": "string",
            "format": "uri"
          },
          "crawlStatus": {
            "$ref": "#/components/schemas/CrawlStatus"
          },
          "crawlError": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "cleanedText": {
            "type": "string"
          },
          "createdAt": {
            "type": "number",
            "description": "Unix timestamp in milliseconds."
          },
          "updatedAt": {
            "type": "number",
            "description": "Unix timestamp in milliseconds."
          },
          "crawledAt": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "description": "Unix timestamp in milliseconds, or null before crawl success."
          }
        },
        "required": [
          "id",
          "sourceUrl",
          "crawlStatus",
          "crawlError",
          "cleanedText",
          "createdAt",
          "updatedAt",
          "crawledAt"
        ],
        "additionalProperties": false
      },
      "CompanionJobsResponse": {
        "type": "object",
        "properties": {
          "jobs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CompanionJob"
            }
          }
        },
        "required": [
          "jobs"
        ],
        "additionalProperties": false
      },
      "DeleteJobResponse": {
        "type": "object",
        "properties": {
          "deleted": {
            "type": "boolean"
          }
        },
        "required": [
          "deleted"
        ],
        "additionalProperties": false
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "getHealth",
        "summary": "Check companion health",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/jobs": {
      "post": {
        "operationId": "createJob",
        "summary": "Create a companion job and enqueue crawling",
        "tags": [
          "Jobs"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateJobRequestInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanionJob"
                }
              }
            }
          },
          "400": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanionErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanionErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listJobs",
        "summary": "List companion jobs",
        "tags": [
          "Jobs"
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanionJobsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{id}": {
      "get": {
        "operationId": "getJob",
        "summary": "Get a companion job",
        "tags": [
          "Jobs"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanionJob"
                }
              }
            }
          },
          "404": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanionErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteJob",
        "summary": "Delete a companion job",
        "tags": [
          "Jobs"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteJobResponse"
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{id}/retry-crawl": {
      "post": {
        "operationId": "retryJobCrawl",
        "summary": "Retry crawling a companion job",
        "tags": [
          "Jobs"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanionJob"
                }
              }
            }
          },
          "404": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanionErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "System",
      "description": "Operational companion endpoints."
    },
    {
      "name": "Jobs",
      "description": "Companion job intake and crawl lifecycle endpoints."
    }
  ]
}
