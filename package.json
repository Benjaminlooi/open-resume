{
	"name": "open-resume-monorepo",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm -r --parallel --filter @open-resume/web --filter @open-resume/backend dev",
		"web:dev": "pnpm --filter @open-resume/web dev",
		"backend:dev": "pnpm --filter @open-resume/backend dev",
		"backend:openapi": "pnpm --filter @open-resume/backend openapi",
		"build": "pnpm -r --filter @open-resume/web --filter @open-resume/backend build",
		"web:build": "pnpm --filter @open-resume/web build",
		"backend:build": "pnpm --filter @open-resume/backend build",
		"preview": "pnpm --filter @open-resume/web preview",
		"web:preview": "pnpm --filter @open-resume/web preview",
		"test": "pnpm -r --filter @open-resume/web --filter @open-resume/backend test",
		"web:test": "pnpm --filter @open-resume/web test",
		"backend:test": "pnpm --filter @open-resume/backend test",
		"typecheck": "pnpm -r --filter @open-resume/web --filter @open-resume/backend --filter @open-resume/contracts typecheck",
		"verify": "pnpm typecheck && pnpm test && pnpm build",
		"lint": "pnpm -r --filter @open-resume/web --filter @open-resume/backend --filter @open-resume/contracts lint",
		"format": "pnpm -r --filter @open-resume/web --filter @open-resume/backend --filter @open-resume/contracts format",
		"check": "pnpm -r --filter @open-resume/web --filter @open-resume/backend --filter @open-resume/contracts check",
		"cf-typegen": "pnpm --filter @open-resume/web cf-typegen",
		"deploy": "pnpm --filter @open-resume/web deploy"
	},
	"devDependencies": {
		"typescript": "^5.9.3"
	}
}
